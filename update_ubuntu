---
- name: Update and Upgrade Apt Packages
  hosts: all
  become: yes  # Required because installing software needs root/sudo privileges

  tasks:
    - name: Update apt cache and upgrade all packages
      ansible.builtin.apt:
        update_cache: yes    # Equivalent to 'apt-get update'
        upgrade: dist        # Equivalent to 'apt-get dist-upgrade'
        cache_valid_time: 3600 # Only updates if the last update was > 1 hour ago

    - name: Remove unused dependency packages
      ansible.builtin.apt:
        autoremove: yes      # Equivalent to 'apt-get autoremove'

    - name: Clean up local repository of retrieved package files
      ansible.builtin.apt:
        autoclean: yes       # Equivalent to 'apt-get autoclean'
